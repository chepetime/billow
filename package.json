{
  "name": "billow",
  "version": "0.1.6",
  "private": true,
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "npm run dev --workspace @billow/web",
    "dev:local": "npm run dev:local --workspace @billow/web",
    "dev:setup": "npm run dev:setup --workspace @billow/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test:run",
    "test:run": "turbo test:run",
    "db:up": "npm run db:up --workspace @billow/web",
    "db:down": "npm run db:down --workspace @billow/web",
    "db:logs": "npm run db:logs --workspace @billow/web",
    "db:generate": "turbo db:generate",
    "db:validate": "npm exec --workspace @billow/web -- prisma validate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed"
  },
  "devDependencies": {
    "turbo": "^2.7.0"
  }
}
