{
  "name": "billow",
  "version": "0.1.8",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @billow/web dev",
    "dev:local": "pnpm --filter @billow/web dev:local",
    "dev:setup": "pnpm --filter @billow/web dev:setup",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test:run",
    "test:run": "turbo test:run",
    "db:up": "pnpm --filter @billow/web db:up",
    "db:down": "pnpm --filter @billow/web db:down",
    "db:logs": "pnpm --filter @billow/web db:logs",
    "db:generate": "turbo db:generate",
    "db:validate": "pnpm --filter @billow/db exec prisma validate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed"
  },
  "devDependencies": {
    "turbo": "^2.7.0"
  }
}
