{
  "name": "@billow/web",
  "version": "0.1.11",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --filter @billow/db db:generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "dev:local": "sh scripts/dev-local.sh",
    "dev:setup": "sh scripts/dev-local.sh --setup-only",
    "db:up": "docker compose -f ../../docker-compose.dev.yml up -d postgres",
    "db:down": "docker compose -f ../../docker-compose.dev.yml down",
    "db:logs": "docker compose -f ../../docker-compose.dev.yml logs -f postgres",
    "db:generate": "pnpm --filter @billow/db db:generate",
    "db:migrate": "pnpm --filter @billow/db db:migrate",
    "db:seed": "pnpm --filter @billow/db db:seed"
  },
  "dependencies": {
    "@billow/db": "workspace:*",
    "@base-ui/react": "^1.6.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
